<launch>
  <!-- rslidar_sdk muss bereits laufen -->

  <!-- Statischer TF: base_link -> rslidar (x y z roll pitch yaw) -->
  <node pkg="tf" type="static_transform_publisher" name="static_tf_rslidar"
        args="0 0 0 0 0 0 base_link rslidar 100" />

  <!-- PointCloud -> LaserScan (dünne z-Scheibe) -->
  <node pkg="pointcloud_to_laserscan" type="cloud_to_scan" name="cloud_to_scan" output="screen">
    <param name="target_frame"        value="base_link"/>
    <param name="transform_tolerance" value="0.02"/>
    <param name="min_height"          value="-0.10"/>
    <param name="max_height"          value="0.10"/>
    <param name="range_min"           value="0.10"/>
    <param name="range_max"           value="20.0"/>
    <remap from="cloud" to="/rslidar_points"/>
    <remap from="scan"  to="/scan"/>
  </node>

  <!-- Hector SLAM -->
  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <param name="base_frame"                 value="base_link"/>
    <param name="odom_frame"                 value="base_link"/>
    <param name="map_frame"                  value="map"/>
    <param name="pub_map_odom_transform"     value="true"/>
    <param name="map_resolution"             value="0.05"/>
    <param name="map_size"                   value="2048"/>
    <param name="update_factor_free"         value="0.4"/>
    <param name="update_factor_occupied"     value="0.9"/>
    <param name="scan_topic"                 value="/scan"/>
  </node>
</launch>
