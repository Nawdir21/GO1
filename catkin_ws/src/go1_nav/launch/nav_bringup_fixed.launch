<?xml version="1.0"?>
<launch>
  <!-- ===== Arguments ===== -->
  <arg name="map_file"   default="$(find go1_nav)/maps/my_map.yaml"/>
  <arg name="start_lidar" default="false"/>  <!-- auf true setzen, wenn du den LiDAR hier mitstarten willst -->

  <!-- ===== Zeitquelle ===== -->
  <param name="use_sim_time" value="false"/>

  <!-- ===== (optional) LiDAR-Treiber einbinden ===== -->
  <group if="$(arg start_lidar)">
    <include file="$(find rslidar_sdk)/launch/start.launch"/>
  </group>

  <!-- ===== DEIN funktionierender Cloud->Scan Konverter ===== -->
  <!-- nimmt /rslidar_points, breiter Höhenfilter, KEIN target_frame erzwungen -->
  <node pkg="pointcloud_to_laserscan"
        type="pointcloud_to_laserscan_node"
        name="pcl_to_scan"
        output="screen">
    <remap from="cloud_in" to="/rslidar_points"/>
    <remap from="scan"    to="/scan"/>
    <param name="min_height" value="-5.0"/>
    <param name="max_height" value="5.0"/>
    <param name="range_min"  value="0.1"/>
    <param name="range_max"  value="20.0"/>
    <param name="transform_tolerance" value="0.3"/>
    <param name="use_inf" value="true"/>
  </node>

  <!-- ===== Statischer TF base_link -> rslidar (Offset ggf. anpassen) ===== -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="lidar_to_base"
        args="0 0 0.35 0 0 0 base_link rslidar"/>

  <!-- ===== Karte laden ===== -->
  <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_file)"/>

  <!-- ===== AMCL ===== -->
  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <param name="base_frame_id"   value="base_link"/>
    <param name="odom_frame_id"   value="odom"/>
    <param name="global_frame_id" value="map"/>
    <param name="scan_topic"      value="/scan"/>
    <param name="tf_broadcast"    value="true"/>
    <rosparam file="$(find go1_nav)/config/amcl_params.yaml" command="load"/>
  </node>

  <!-- ===== move_base ===== -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <param name="controller_frequency" value="10.0"/>
    <param name="planner_frequency"    value="1.0"/>

    <rosparam file="$(find go1_nav)/config/costmap_common_params.yaml"  command="load"/>
    <rosparam file="$(find go1_nav)/config/global_costmap_params.yaml"   command="load"/>
    <rosparam file="$(find go1_nav)/config/local_costmap_params.yaml"    command="load"/>
    <rosparam file="$(find go1_nav)/config/dwa_local_planner_params.yaml" command="load"/>

    <!-- Falls dein GO1-Treiber NICHT /cmd_vel hört, hier remappen:
         <remap from="cmd_vel" to="/go1/cmd_vel"/> -->
  </node>
</launch>
