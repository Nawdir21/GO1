<launch>
  <arg name="start_rslidar" default="false"/>
  <arg name="cloud_in"   default="/rslidar_points"/>
  <arg name="scan_in"    default="/scan"/>
  <arg name="scan_sync"  default="/scan_sync"/>
  <arg name="start_rviz" default="true"/>

  <!-- Optional: RoboSense-Treiber -->
  <group if="$(arg start_rslidar)">
    <include file="$(find rslidar_sdk)/launch/start.launch"/>
  </group>

  <!-- Cloud -> LaserScan -->
  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="cloud2scan" output="screen" respawn="true">
    <param name="target_frame" value="rslidar"/>
    <param name="min_height" value="-0.12"/>
    <param name="max_height" value="0.12"/>
    <param name="range_min"  value="0.20"/>
    <param name="range_max"  value="12.0"/>
    <remap from="cloud_in" to="$(arg cloud_in)"/>
    <remap from="scan"     to="$(arg scan_in)"/>
  </node>

  <!-- Scan Retimer (setzt Zeitstempel auf now) -->
  <node pkg="my_nav" type="scan_retime.py" name="scan_retime" output="screen" respawn="true">
    <param name="in"       value="$(arg scan_in)"/>
    <param name="out"      value="$(arg scan_sync)"/>
    <param name="frame_id" value="rslidar"/>
  </node>

  <!-- Statische TF rslidar -> base_link (Offsets ggf. anpassen) -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="rslidar_tf"
        args="0 0 0 0 0 0 base_link rslidar" />

  <!-- Hector SLAM baut Map (& liefert map->base_link) -->
  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="base_link"/>
    <param name="map_frame"  value="map"/>
    <param name="pub_map_odom_transform" value="true"/>
    <remap from="scan" to="$(arg scan_sync)"/>
  </node>

  <!-- RViz -->
  <group if="$(arg start_rviz)">
    <node pkg="rviz" type="rviz" name="rviz"/>
  </group>
</launch>
